# ─── NVIDIA / NemoClaw ──────────────────────────────────────────────────────
# Get from https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx

# ─── AWS ────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# ECR repository name (from: terraform output ecr_repository_url)
ECR_REPOSITORY=nemoclaw

# ECS config (from: terraform output)
ECS_CLUSTER=nemoclaw-staging
ECS_SERVICE=nemoclaw-staging-svc
ECS_TASK_FAMILY=nemoclaw-staging

# Container config
CONTAINER_NAME=nemoclaw
CONTAINER_PORT=3000

# ─── Notifications (optional) ───────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXXXXXX/XXXXXXXXX/xxxxxxxx

# ─── Terraform backend ──────────────────────────────────────────────────────
TF_BACKEND_BUCKET=your-nemoclaw-tfstate
TF_BACKEND_REGION=us-east-1
